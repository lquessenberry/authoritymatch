# ========================================
# AuthorityMatch Environment Variables
# ========================================

# Drupal Backend
DRUPAL_GRAPHQL_ENDPOINT=http://authoritymatch.ddev.site/graphql
DRUPAL_BASE_URL=http://authoritymatch.ddev.site

# OAuth / Authentication
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_TOKEN_URL=http://authoritymatch.ddev.site/oauth/token

# Next.js Frontend
NEXT_PUBLIC_DRUPAL_BASE_URL=http://authoritymatch.ddev.site
NEXT_PUBLIC_GRAPHQL_ENDPOINT=http://authoritymatch.ddev.site/graphql

# Database (Drupal)
DATABASE_URL=mysql://db:db@db/db

# File Storage
# S3/B2 for production file storage
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Payments - Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email - Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@authoritymatch.com

# FMCSA API
FMCSA_API_KEY=your-fmcsa-api-key
FMCSA_API_URL=https://mobile.fmcsa.dot.gov/qc/services

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Fly.io / Production
FLY_REGION=ord
FLY_APP_DRUPAL=authoritymatch-drupal
FLY_APP_WEB=authoritymatch-web
FLY_APP_DASHBOARD=authoritymatch-dashboard
