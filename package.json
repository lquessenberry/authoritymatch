{
  "name": "authoritymatch",
  "private": true,
  "description": "AuthorityMatch — Connecting truckers with factoring partners",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "design-system:lint": "pnpm --filter @authoritymatch/ui lint",
    "design-system:type-check": "pnpm --filter @authoritymatch/ui type-check",
    "design-system:check-duplicates": "node ./scripts/check-design-system-duplicates.mjs",
    "design-system:check": "pnpm design-system:lint && pnpm design-system:type-check && pnpm design-system:check-duplicates",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,js,css}\"",
    "drupal:install": "cd drupal && ddev install",
    "drupal:start": "cd drupal && ddev start",
    "drupal:stop": "cd drupal && ddev stop",
    "fly:deploy:drupal": "fly deploy --config infra/fly/drupal/fly.toml",
    "fly:deploy:web": "fly deploy --config infra/fly/web/fly.toml",
    "fly:deploy:dashboard": "fly deploy --config infra/fly/dashboard/fly.toml",
    "fly:deploy:pipeline": "fly deploy --config infra/fly/pipeline/fly.toml",
    "dev:web": "cd apps/web/nextjs && pnpm dev",
    "dev:dashboard": "cd apps/dashboard && pnpm dev"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
